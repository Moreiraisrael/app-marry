-2'],\n  occasion: 'Trabalho',\n  description: 'Elegante para reuni├Áes',\n  created_at: new Date().toISOString(),\n  client_name: 'Maria Fernanda',\n  item_photos: [],\n}\n\n// ÔöÇÔöÇÔöÇ Tests ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ\n\ndescribe('CapsuleCard', () => {\n  it('exibe o nome do look', () => {\n    render(<CapsuleCard capsule={baseCapsule} index={0} />)\n    expect(screen.getByText('Look de Trabalho')).toBeInTheDocument()\n  })\n\n  it('exibe o nome da cliente', () => {\n    render(<CapsuleCard capsule={baseCapsule} index={0} />)\n    expect(screen.getByText('Maria Fernanda')).toBeInTheDocument()\n  })\n\n  it('exibe a contagem correta de pe├ºas (2 pe├ºas)', () => {\n    render(<CapsuleCard capsule={baseCapsule} index={0} />)\n    expect(screen.getByText('2 pe├ºas')).toBeInTheDocument()\n  })\n\n  it('exibe o badge de ocasi├úo', () => {\n    render(<CapsuleCard capsule={baseCapsule} index={0} />)\n    expect(screen.getByText('Trabalho')).toBeInTheDocument()\n  })\n\n  it('exibe \"Cliente\" como fallback quando client_name ├® null', () => {\n    render(<CapsuleCard capsule={{ ...baseCapsule, client_name: null }} index={0} />)\n    expect(screen.getByText('Cliente')).toBeInTheDocument()\n  })\n\n  it('n├úo quebra quando item_ids est├í vazio (0 pe├ºas)', () => {\n    render(<CapsuleCard capsule={{ ...baseCapsule, item_ids: [] }} index={0} />)\n    expect(screen.getByText('0 pe├ºas')).toBeInTheDocument()\n  })\n\n  it('renderiza imagem quando h├í 1 photo', () => {\n    const capsuleWithPhoto = {\n      ...baseCapsule,\n      item_photos: ['https://example.com/photo.jpg'],\n    }\n    render(<CapsuleCard capsule={capsuleWithPhoto} index={0} />)\n    const img = screen.getByRole('img', { name: 'Look de Trabalho' })\n    expect(img).toHaveAttribute('src', 'https://example.com/photo.jpg')\n  })\n\n  it('renderiza 4 imagens em mosaico quando h├í 4 fotos', () => {\n    const capsuleWithPhotos = {\n      ...baseCapsule,\n      item_photos: [\n        'https://example.com/1.jpg',\n        'https://example.com/2.jpg',\n        'https://example.com/3.jpg',\n        'https://example.com/4.jpg',\n      ],\n    }\n    render(<CapsuleCard capsule={capsuleWithPhotos} index={0} />)\n    expect(screen.getAllByRole('img')).toHaveLength(4)\n  })\n})\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\israe\\aplicatvo marry\\src\\__tests__\\ClientsTable.test.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\israe\\aplicatvo marry\\src\\__tests__\\capsules.test.ts","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'vi' is defined but never used.","line":1,"column":32,"nodeType":"Identifier","messageId":"unusedVar","endLine":1,"endColumn":34,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"vi"},"fix":{"range":[29,33],"text":""},"desc":"Remove unused variable \"vi\"."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { describe, it, expect, vi } from 'vitest'\n\n// ÔöÇÔöÇÔöÇ Types (local mirror to avoid \"use server\" import) ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ\n\ninterface LookCapsule {\n  id: string\n  client_id: string\n  name: string\n  item_ids: string[]\n  occasion: string | null\n  description: string | null\n  created_at: string\n  client_name?: string | null\n  item_photos?: string[]\n}\n\n// ÔöÇÔöÇÔöÇ Helpers ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ\n\nconst makeCapsule = (overrides: Partial<LookCapsule> = {}): LookCapsule => ({\n  id: 'cap-1',\n  client_id: 'client-1',\n  name: 'Look Casual',\n  item_ids: ['item-1', 'item-2'],\n  occasion: 'Casual',\n  description: 'Look leve para o dia a dia',\n  created_at: new Date().toISOString(),\n  client_name: 'Ana Silva',\n  item_photos: [],\n  ...overrides,\n})\n\n// ÔöÇÔöÇÔöÇ Business logic helpers ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ\n\n// Mirrors the display logic from CapsuleCard and getLookCapsules\nfunction getDisplayClientName(capsule: LookCapsule): string {\n  return capsule.client_name || 'Cliente'\n}\n\nfunction getPieceCount(capsule: LookCapsule): number {\n  return capsule.item_ids?.length || 0\n}\n\nfunction buildPhotoMosaic(photos: string[]): string[] {\n  return photos.slice(0, 4)\n}\n\nfunction isValidCapsule(data: Partial<LookCapsule>): boolean {\n  return !!(data.client_id && data.name && data.item_ids && data.item_ids.length > 0)\n}\n\n// ÔöÇÔöÇÔöÇ Tests ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ\n\ndescribe('LookCapsule ÔÇö l├│gica de exibi├º├úo', () => {\n  it('retorna nome da cliente quando client_name existe', () => {\n    const capsule = makeCapsule({ client_name: 'Maria Fernanda' })\n    expect(getDisplayClientName(capsule)).toBe('Maria Fernanda')\n  })\n\n  it('retorna \"Cliente\" como fallback quando client_name ├® null', () => {\n    const capsule = makeCapsule({ client_name: null })\n    expect(getDisplayClientName(capsule)).toBe('Cliente')\n  })\n\n  it('retorna \"Cliente\" quando client_name ├® undefined', () => {\n    const capsule = makeCapsule({ client_name: undefined })\n    expect(getDisplayClientName(capsule)).toBe('Cliente')\n  })\n\n  it('conta pe├ºas corretamente com 2 itens', () => {\n    const capsule = makeCapsule({ item_ids: ['a', 'b'] })\n    expect(getPieceCount(capsule)).toBe(2)\n  })\n\n  it('conta pe├ºas como 0 quando item_ids ├® vazio', () => {\n    const capsule = makeCapsule({ item_ids: [] })\n    expect(getPieceCount(capsule)).toBe(0)\n  })\n\n  it('mosaico limita a no m├íximo 4 fotos', () => {\n    const photos = ['1.jpg', '2.jpg', '3.jpg', '4.jpg', '5.jpg']\n    expect(buildPhotoMosaic(photos)).toHaveLength(4)\n  })\n\n  it('mosaico retorna todas as fotos quando h├í menos de 4', () => {\n    const photos = ['1.jpg', '2.jpg']\n    expect(buildPhotoMosaic(photos)).toHaveLength(2)\n  })\n\n  it('mosaico retorna array vazio quando n├úo h├í fotos', () => {\n    expect(buildPhotoMosaic([])).toHaveLength(0)\n  })\n})\n\ndescribe('LookCapsule ÔÇö valida├º├úo de cria├º├úo', () => {\n  it('valida dados completos como v├ílidos', () => {\n    const data = {\n      client_id: 'client-1',\n      name: 'Look Casual',\n      item_ids: ['item-1', 'item-2'],\n    }\n    expect(isValidCapsule(data)).toBe(true)\n  })\n\n  it('invalida quando client_id est├í ausente', () => {\n    const data = { name: 'Look', item_ids: ['item-1'] }\n    expect(isValidCapsule(data)).toBe(false)\n  })\n\n  it('invalida quando name est├í ausente', () => {\n    const data = { client_id: 'client-1', item_ids: ['item-1'] }\n    expect(isValidCapsule(data)).toBe(false)\n  })\n\n  it('invalida quando item_ids est├í vazio (look sem pe├ºas)', () => {\n    const data = { client_id: 'client-1', name: 'Look', item_ids: [] }\n    expect(isValidCapsule(data)).toBe(false)\n  })\n})\n\ndescribe('LookCapsule ÔÇö ocasi├Áes permitidas', () => {\n  const VALID_OCCASIONS = ['Trabalho', 'Social', 'Casual', 'Evento', 'Esporte', 'Viagem']\n\n  it('aceita todas as ocasi├Áes permitidas', () => {\n    VALID_OCCASIONS.forEach(occ => {\n      const capsule = makeCapsule({ occasion: occ })\n      expect(VALID_OCCASIONS).toContain(capsule.occasion)\n    })\n  })\n\n  it('permite occasion null (look sem categoria)', () => {\n    const capsule = makeCapsule({ occasion: null })\n    expect(capsule.occasion).toBeNull()\n  })\n})\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\israe\\aplicatvo marry\\src\\__tests__\\clients-actions.test.ts","messages":[],"suppressedMe