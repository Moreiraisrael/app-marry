warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\israe\\aplicatvo marry\\src\\app\\client\\profile\\ProfileClient.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":13,"column":55,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":13,"endColumn":58,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[467,470],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[467,470],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'_state' is assigned a value but never used.","line":14,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":14,"endColumn":16}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\"\n\nimport { useActionState } from \"react\"\nimport Image from \"next/image\"\nimport { Card } from \"@/components/ui/card\"\nimport { User, Save, Sparkles, Heart } from \"lucide-react\"\nimport { Button } from \"@/components/ui/button\"\nimport { Input } from \"@/components/ui/input\"\nimport { Label } from \"@/components/ui/label\"\nimport { updateProfile } from \"@/lib/actions/profile\"\nimport { toast } from \"sonner\"\n\nexport function ProfileClient({ profile }: { profile: any }) {\n  const [_state, formAction, isPending] = useActionState(\n    async (_prevState: unknown, formData: FormData) => {\n      const result = await updateProfile(formData)\n      if (result.success) {\n        toast.success(result.success)\n      } else if (result.error) {\n        toast.error(result.error)\n      }\n      return result\n    },\n    null\n  )\n\n  return (\n    <div className=\"max-w-4xl mx-auto space-y-10 animate-in fade-in slide-in-from-bottom-4 duration-1000\">\n      <div>\n        <div className=\"flex items-center gap-2 mb-2 text-primary font-bold tracking-[0.2em] uppercase text-[10px]\">\n          <User className=\"w-4 h-4\" /> ├ürea da Cliente\n        </div>\n        <h1 className=\"text-4xl md:text-5xl font-serif text-foreground tracking-tight mb-2 text-white\">Meu Perfil</h1>\n        <p className=\"text-neutral-400 font-light text-lg\">Gerencie suas informa├º├Áes pessoais e prefer├¬ncias de estilo.</p>\n      </div>\n\n      <div className=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n        <div className=\"md:col-span-1 space-y-6\">\n          <div className=\"p-8 rounded-[2.5rem] bg-white/60 backdrop-blur-xl border-none shadow-sm shadow-primary/5 text-center\">\n            <div className=\"w-24 h-24 mx-auto rounded-3xl bg-primary flex items-center justify-center shadow-2xl shadow-primary/20 mb-6 ring-4 ring-white overflow-hidden relative\">\n              {profile?.avatar_url ? (\n                <Image src={profile.avatar_url} alt=\"Avatar\" fill className=\"object-cover\" />\n              ) : (\n                <User className=\"w-12 h-12 text-primary-foreground\" />\n              )}\n            </div>\n            <h2 className=\"text-xl font-bold text-foreground mb-1\">{profile?.full_name || 'Cliente'}</h2>\n            <p className=\"text-primary text-[10px] font-bold uppercase tracking-widest\">{profile?.user_type === 'consultant' ? 'Consultora VIP' : 'Membro Premium'}</p>\n          </div>\n          \n          <div className=\"p-8 rounded-[2.5rem] bg-white/60 backdrop-blur-xl border-none shadow-sm shadow-primary/5\">\n            <div className=\"flex items-center gap-3 mb-6\">\n              <div className=\"p-2 bg-primary/10 rounded-xl\">\n                <Sparkles className=\"w-5 h-5 text-primary\" />\n              </div>\n              <h3 className=\"text-xs font-bold text-foreground uppercase tracking-widest\">Resumo de Estilo</h3>\n            </div>\n            <div className=\"space-y-4\">\n               {[\n                 { label: 'Cartela', value: profile?.season || 'N├úo Definida' },\n                 { label: 'Arqu├®tipo', value: profile?.style_archetypes?.[0] || 'N├úo Definido' },\n                 { label: 'Estilo', value: 'Elegante' },\n               ].map((item, i) => (\n                 <div key={i} className=\"flex justify-between items-center text-xs\">\n                    <span className=\"text-muted-foreground font-medium uppercase tracking-tighter\">{item.label}</span>\n                    <span className=\"text-foreground font-bold\">{item.value}</span>\n                 </div>\n               ))}\n            </div>\n          </div>\n        </div>\n\n        <div className=\"md:col-span-2\">\n          <form action={formAction}>\n            <Card className=\"border-none bg-white/60 backdrop-blur-xl rounded-[2.5rem] p-8 shadow-sm shadow-primary/5\">\n              <h3 className=\"text-2xl font-serif text-foreground mb-8 border-b border-border/50 pb-4 flex items-center gap-3\">\n                 <Heart className=\"w-6 h-6 text-primary\" /> Dados Pessoais\n              </h3>\n              <div className=\"space-y-8\">\n                <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n                  <div className=\"space-y-3\">\n                    <Label className=\"text-[10px] text-muted-foreground uppercase tracking-[0.2em] font-bold\">Nome Completo</Label>\n                    <Input name=\"fullName\" className=\"bg-white/80 border-border/50 text-foreground rounded-2xl h-12\" defaultValue={profile?.full_name || ''} />\n                  </div>\n                  <div className=\"space-y-3\">\n                    <Label className=\"text-[10px] text-muted-foreground uppercase tracking-[0.2em] font-bold\">E-mail</Label>\n                    <Input name=\"email\" className=\"bg-secondary/40 border-transparent text-foreground/60 rounded-2xl h-12\" defaultValue={profile?.email || ''} disabled />\n                  </div>\n                </div>\n\n                <div className=\"space-y-3\">\n                  <Label className=\"text-[10px] text-muted-foreground uppercase tracking-[0.2em] font-bold\">Sobre meu Estilo (Bio)</Label>\n                  <textarea name=\"bio\" className=\"w-full bg-white/80 border border-border/50 text-foreground rounded-2xl p-5 min-h-[120px] text-sm focus:ring-primary/20 transition-all outline-none font-medium leading-relaxed\" placeholder=\"Conte um pouco sobre suas prefer├¬ncias de cores e estilo...\" defaultValue={profile?.bio || ''} />\n                </div>\n                \n                <div className=\"flex justify-end pt-4\">\n                  <Button \n                    type=\"submit\" \n                    disabled={isPending}\n                    className=\"bg-primary hover:bg-primary/90 text-primary-foreground rounded-2xl px-12 h-14 gap-3 shadow-xl shadow-primary/20 transition-all hover:scale-[1.02] active:scale-98 font-bold uppercase tracking-widest text-xs\"\n                  >\n                    {isPending ? <Sparkles className=\"w-4 h-4 animate-spin\" /> : <Save className=\"w-5 h-5\" />}\n                    {isPending ? \"Salvando...\" : \"Salvar Altera├º├Áes\"}\n                  </Button>\n                </div>\n              </div>\n            </Card>\n          </form>\n        </div>\n      </div>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\israe\\aplicatvo marry\\src\\app\\client\\profile\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\israe\\aplicatvo marry\\src\\app\\client\\quiz\\archetypes\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'_' is defined but never used.","line":208,"column":41,"nodeType":"Identifier","messageId":"unusedVar","endLine":208,"endColumn":42}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\"\n\nimport { useState } from \"react\"\nimport { Card, CardContent, CardFooter, CardHeader, CardTitle } from \"@/components/ui/card\"\nimport { Button } from \"@/components/ui/button\"\nimport { Progress } from \"@/components/ui/progress\"\nimport { ArrowLeft, ArrowRight, CheckCircle2, Sparkles, Star, RefreshCw } from \"lucide-react\"\nimport { motion } from \"framer-motion\"\nimport { saveQuizResult } from \"@/lib/actions/quizzes\"\nimport { useRouter } from \"next/navigation\"\n\nconst questions = [\n  {\n    id: 1,\n    question: \"Como voc├¬ prefere passar seu dia livre?\",\n    options: [\n      { id: \"1a\", text: \"Em casa com velas, flores e um bom livro\", archetype: \"romantica\" },\n      { id: \"1b\", text: \"Em um museu, galeria de arte ou caf├® elegante\", archetype: \"classica\" },\n      { id: \"1c\", text: \"Em um evento exclusivo ou jantar sofisticado\", archetype: \"dramatica\" },\n      { id: \"1d\", text: \"Na natureza, parque ou passeio ao ar livre\", archetype: \"natural\" },\n      { id: \"1e\", text: \"Explorando brech├│s, feiras de arte ou vielas criativas\", archetype: \"criativa\" },\n      { id: \"1f\", text: \"Praticando esporte, academia ou yoga\", archetype: \"esportiva\" },\n    ]\n  },\n  {\n    id: 2,\n    question: \"Qual palavra melhor descreve seu estilo ideal?\",\n    options: [\n      { id: \"2a\", text: \"Delicado e feminino\", archetype: \"romantica\" },\n      { id: \"2b\", text: \"Elegante e atemporal\", archetype: \"classica\" },\n      { id: \"2c\", text: \"Marcante e sofisticado\", archetype: \"dramatica\" },\n      { id: \"2d\", text: \"Despojado e aut├¬ntico\", archetype: \"natural\" },\n      { id: \"2e\", text: \"├Ünico e expressivo\", archetype: \"criativa\" },\n      { id: \"2f\", text: \"Funcional e moderno\", archetype: \"esportiva\" },\n    ]\n  },\n  {\n    id: 3,\n    question: \"Que tipo de tecido te atrai mais?\",\n    options: [\n      { id: \"3a\", text: \"Seda, renda, chiffon e cetim\", archetype: \"romantica\" },\n      { id: \"3b\", text: \"Linho, l├ú e algod├úo estruturado\", archetype: \"classica\" },\n      { id: \"3c\", text: \"Couro, veludo e tecidos com textura rica\", archetype: \"dramatica\" },\n      { id: \"3d\", text: \"Algod├úo, linho lavado e tecidos naturais\", archetype: \"natural\" },\n      { id: \"3e\", text: \"Misturas inesperadas e tecidos artesanais\", archetype: \"criativa\" },\n      { id: \"3f\", text: \"Tecidos t├®cnicos, moletom premium e neoprene\", archetype: \"esportiva\" },\n    ]\n  },\n  {\n    id: 4,\n    question: \"Como ├® a sua maquiagem ideal?\",\n    options: [\n      { id: \"4a\", text: \"Rosinha, batom nude e blush suave\", archetype: \"romantica\" },\n      { id: \"4b\", text: \"Natural e bem cuidada, nada excessivo\", archetype: \"classica\" },\n      { id: \"4c\", text: \"Olho marcado, batom vermelho ou l├íbio poderoso\", archetype: \"dramatica\" },\n      { id: \"4d\", text: \"Quase sem maquiagem, skin care em foco\", archetype: \"natural\" },\n      { id: \"4e\", text: \"Experimental ÔÇô delineado colorido, glitter, graphic liner\", archetype: \"criativa\" },\n      { id: \"4f\", text: \"BB cream e protetor solar, praticidade total\", archetype: \"esportiva\" },\n    ]\n  },\n  {\n    id: 5,\n    question: \"Que ambiente te inspira mais?\",\n    options: [\n      { id: \"5a\", text: \"Jardins floridos, castelos, Paris em primavera\", archetype: \"romantica\" },\n      { id: \"5b\", text: \"Hot├®is cl├íssicos, escrit├│rios modernos e museus\", archetype: \"classica\" },\n      { id: \"5c\", text: \"Arranha-c├®us, moda de alto padr├úo, NY Fashion Week\", archetype: \"dramatica\" },\n      { id: \"5d\", text: \"Fazendas, campos abertos, praia sem filtro\", archetype: \"natural\" },\n      { id: \"5e\", text: \"Bairros bo├¬mios, feiras de arte, ateliers\", archetype: \"criativa\" },\n      { id: \"5f\", text: \"Academia, trilhas, eventos ao ar livre\", archetype: \"esportiva\" },\n    ]\n  },\n  {\n    id: 6,\n    question: \"Como voc├¬ escolhe suas cores favoritas?\",\n    options: [\n      { id: \"6a\", text: \"Tons pastel, ros├®, lil├ís e tons de baunilha\", archetype: \"romantica\" },\n      { id: \"6b\", text: \"Neutros sofisticados: navy, bege, cinza e branco\", archetype: \"classica\" },\n      { id: \"6c\", text: \"Alto contraste: preto, branco e um acento forte\", archetype: \"dramatica\" },\n      { id: \"6d\", text: \"Tons terrosos, verde, caramelo e areia\", archetype: \"natural\" },\n      { id: \"6e\", text: \"Combina├º├Áes inesperadas e cores vibrantes\", archetype: \"criativa\" },\n      { id: \"6f\", text: \"Cores vivas e funcionais, sem medo do colorido\", archetype: \"esportiva\" },\n    ]\n  },\n  {\n    id: 7,\n    question: \"Qual acess├│rio n├úo pode faltar no seu look?\",\n    options: [\n      { id: \"7a\", text: \"Brinco p├®rola, la├ºo ou flor nos cabelos\", archetype: \"romantica\" },\n      { id: \"7b\", text: \"Rel├│gio cl├íssico ou colar discreto de ouro\", archetype: \"classica\" },\n      { id: \"7c\", text: \"Statement jewelry ÔÇô maxi brincos ou colar poderoso\", archetype: \"dramatica\" },\n      { id: \"7d\", text: \"Bolsa de couro natural, sand├ília rasteira ou chap├®u\", archetype: \"natural\" },\n      { id: \"7e\", text: \"Acess├│rios vintage, artesanais ou inusitados\", archetype: \"criativa\" },\n      { id: \"7f\", text: \"T├¬nis de grife, mochila funcional ou bon├®\", archetype: \"esportiva\" },\n    ]\n  },\n  {\n    id: 8,\n    question: \"Como voc├¬ se relaciona com tend├¬ncias da moda?\",\n    options: [\n      { id: \"8a\", text: \"Prefiro looks atemporais com toque feminino\", archetype: \"romantica\" },\n      { id: \"8b\", text: \"S├│ adoto tend├¬ncias que s├úo cl├íssicas e discretas\", archetype: \"classica\" },\n      { id: \"8c\", text: \"Sou a primeira a usar o que aparece nas passarelas\", archetype: \"dramatica\" },\n      { id: \"8d\", text: \"Ignoro tend├¬ncias ÔÇô uso o que me faz bem\", archetype: \"natural\" },\n      { id: \"8e\", text: \"Misturo tend├¬ncias com pe├ºas vintage e artesanais\", archetype: \"criativa\" },\n      { id: \"8f\", text: \"Adoto tend├¬ncias que sejam confort├íveis e pr├íticas\", archetype: \"esportiva\" },\n    ]\n  },\n  {\n    id: 9,\n    question: \"Como voc├¬ quer ser percebida pelas pessoas?\",\n    options: [\n      { id: \"9a\", text: \"Doce, encantadora e feminina\", archetype: \"romantica\" },\n      { id: \"9b\", text: \"Elegante, confiante e profissional\", archetype: \"classica\" },\n      { id: \"9c\", text: \"Poderosa, marcante e sofisticada\", archetype: \"dramatica\" },\n      { id: \"9d\", text: \"Aut├¬ntica, leve e sem esfor├ºo aparente\", archetype: \"natural\" },\n      { id: \"9e\", text: \"Original, art├¡stica e cheia de personalidade\", archetype: \"criativa\" },\n      { id: \"9f\", text: \"Ativa, moderna e cheia de energia\", archetype: \"esportiva\" },\n    ]\n  },\n  {\n    id: 10,\n    question: \"Qual look voc├¬ escolheria para uma ocasi├úo especial?\",\n    options: [\n      { id: \"10a\", text: \"Vestido fluido com florais, renda ou babados delicados\", archetype: \"romantica\" },\n      { id: \"10b\", text: \"Conjunto estruturado em neutro com acess├│rio cl├íssico\", archetype: \"classica\" },\n      { id: \"10c\", text: \"Vestido longo dram├ítico ou blazer oversized impactante\", archetype: \"dramatica\" },\n      { id: \"10d\", text: \"Linho bem cortado ou jumpsuit minimalista em tom terra\", archetype: \"natural\" },\n      { id: \"10e\", text: \"Mix de estampas, pe├ºas vintage e acess├│rios autorais\", archetype: \"criativa\" },\n      { id: \"10f\", text: \"Look esportivo chique com t├¬nis de grife e pe├ºas t├®cnicas premium\", archetype: \"esportiva\" },\n    ]\n  }\n]\n\nconst archetypes = {\n  romantica: {\n    name: \"Rom├óntica\",\n    emoji: \"­ƒî©\",\n    color: \"from-rose-400 to-pink-500\",\n    bg: \"bg-rose-50\",\n    border: \"border-rose-200\",\n    description: \"Voc├¬ ├® a mulher dos detalhes delicados, das flores e da feminilidade pura. Seu estilo encanta pelo romantismo e suavidade que transmite.\",\n    keywords: [\"Feminino\", \"Delicado\", \"Encantador\", \"Suave\"]\n  },\n  classica: {\n    name: \"Cl├íssica\",\n    emoji: \"­ƒææ\",\n    color: \"from-amber-600 to-yellow-700\",\n    bg: \"bg-amber-50\",\n    border: \"border-amber-200\",\n    description: \"Voc├¬ tem eleg├óncia intemporal. Seu estilo ├® refinado, equilibrado e nunca passa de moda. A sofistica├º├úo discreta ├® sua marca registrada.\",\n    keywords: [\"Elegante\", \"Atemporal\", \"Refinado\", \"Polido\"]\n  },\n  dramatica: {\n    name: \"Dram├ítica\",\n    emoji: \"ÔÜí\",\n    color: \"from-purple-600 to-indigo-700\",\n    bg: \"bg-purple-50\",\n    border: \"border-purple-200\",\n    description: \"Voc├¬ ├® presen├ºa! Poderosa, marcante e sofisticada, voc├¬ n├úo passa despercebida. Seu estilo comunica autoridade e impacto visual.\",\n    keywords: [\"Marcante\", \"Poderosa\", \"Sofisticada\", \"Impactante\"]\n  },\n  natural: {\n    name: \"Natural\",\n    emoji: \"­ƒî┐\",\n    color: \"from-green-500 to-emerald-600\",\n    bg: \"bg-green-50\",\n    border: \"border-green-200\",\n    description: \"Voc├¬ valoriza o conforto, a autenticidade e a leveza. Seu estilo parece sem esfor├ºo mas ├® cheio de inten├º├úo.\",\n    keywords: [\"Aut├¬ntico\", \"Confort├ível\", \"Org├ónico\", \"Despojado\"]\n  },\n  criativa: {\n    name: \"Criativa\",\n    emoji: \"­ƒÄ¿\",\n    color: \"from-orange-400 to-rose-500\",\n    bg: \"bg-orange-50\",\n    border: \"border-orange-200\",\n    description: \"Voc├¬ ├® uma obra de arte ambulante! Expressiva, original e sem medo do julgamento alheio.\",\n    keywords: [\"Criativa\", \"Original\", \"Art├¡stica\", \"Expressiva\"]\n  },\n  esportiva: {\n    name: \"Esportiva\",\n    emoji: \"ÔÜí\",\n    color: \"from-sky-500 to-blue-600\",\n    bg: \"bg-sky-50\",\n    border: \"border-sky-200\",\n    description: \"Voc├¬ vive em movimento! Moderna, funcional e com energia contagiante.\",\n    keywords: [\"Ativa\", \"Funcional\", \"Moderna\", \"Energ├®tica\"]\n  }\n}\n\nexport default function ArchetypeQuiz() {\n  const router = useRouter()\n  const [currentStep, setCurrentStep] = useState(0)\n  const [answers, setAnswers] = useState<Record<number, string>>({})\n  const [result, setResult] = useState<{ primary: string; secondary: string | null } | null>(null)\n  const [isSaving, setIsSaving] = useState(false)\n\n  const progress = ((currentStep) / questions.length) * 100\n  const currentQ = questions[currentStep]\n\n  const handleNext = async () => {\n    if (currentStep < questions.length - 1) {\n      setCurrentStep(c => c + 1)\n    } else {\n      // Calculate results\n      const scores: Record<string, number> = {}\n      Object.entries(answers).forEach(([_, arc]) => {\n        scores[arc] = (scores[arc] || 0) + 1\n      })\n      const sorted = Object.entries(scores).sort((a, b) => b[1] - a[1])\n      const primary = sorted[0][0]\n      const secondary = sorted[1]?.[1] === sorted[0][1] ? null : (sorted[1]?.[0] || null)\n      \n      const resultObj = { primary, secondary }\n      setResult(resultObj)\n      \n      // Save to DB\n      setIsSaving(true)\n      await saveQuizResult('archetype', answers, primary)\n      setIsSaving(false)\n    }\n  }\n\n  const handleBack = () => {\n    if (currentStep > 0) setCurrentStep(c => c - 1)\n  }\n\n  if (result) {\n    const primaryInfo = (archetypes as Record<string, typeof archetypes.romantica>)[result.primary]\n    const secondaryInfo = result.secondary ? (archetypes as Record<string, typeof archetypes.romantica>)[result.secondary] : null\n\n    return (\n      <div className=\"max-w-3xl mx-auto py-12 px-4 animate-in zoom-in duration-700\">\n        <div className={`rounded-[3rem] overflow-hidden shadow-[0_32px_64px_-16px_rgba(0,0,0,0.15)] bg-white border border-stone-100`}>\n          <div className={`bg-gradient-to-br ${primaryInfo.color} p-12 text-white text-center relative overflow-hidden`}>\n            <div className=\"absolute inset-0 bg-black/5 mix-blend-overlay\" />\n            <div className=\"relative z-10\">\n              <div className=\"text-8xl mb-6 drop-shadow-2xl animate-bounce-slow\">{primaryInfo.emoji}</div>\n              <p className=\"text-white/80 text-[10px] uppercase tracking-[0.3em] font-bold mb-3\">Seu Arqu├®tipo Dominante</p>\n              <h1 className=\"text-6xl font-serif font-bold mb-6 tracking-tight\">{primaryInfo.name}</h1>\n              <div className=\"flex flex-wrap justify-center gap-2.5 mt-8\">\n                {primaryInfo.keywords.map((k: string) => (\n                  <span key={k} className=\"px-6 py-2 bg-white/20 backdrop-blur-xl rounded-full text-xs font-bold uppercase tracking-wider border border-white/20\">{k}</span>\n                ))}\n              </div>\n            </div>\n          </div>\n\n          <div className=\"p-10 md:p-14 space-y-12\">\n            <p className=\"text-stone-600 text-2xl leading-relaxed text-center font-serif italic max-w-2xl mx-auto\">\n              &quot;{primaryInfo.description}&quot;\n            </p>\n\n            {secondaryInfo && (\n              <div className={`${secondaryInfo.bg} ${secondaryInfo.border} border-2 rounded-[2rem] p-8 transition-all hover:shadow-xl group`}>\n                <p className=\"text-[10px] font-bold text-stone-400 uppercase tracking-[0.2em] mb-3\">Influ├¬ncia Secund├íria</p>\n                <div className=\"flex items-center gap-4 mb-4\">\n                  <span className=\"text-3xl group-hover:scale-110 transition-transform\">{secondaryInfo.emoji}</span>\n                  <p className=\"text-2xl font-bold text-stone-900 tracking-tight\">{secondaryInfo.name}</p>\n                </div>\n                <p className=\"text-stone-600 text-base leading-relaxed\">{secondaryInfo.description}</p>\n              </div>\n            )}\n\n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n               <div className=\"bg-stone-50/50 rounded-3xl p-8 border border-stone-100\">\n                  <h4 className=\"text-stone-900 font-bold mb-4 flex items-center gap-3 text-lg\">\n                    <Star className=\"w-5 h-5 text-[#B48D6C]\" /> Superpoderes\n                  </h4>\n                  <ul className=\"text-stone-600 space-y-3\">\n                    <li className=\"flex items-center gap-2\">ÔÇó <span className=\"text-sm\">Comunica├º├úo visual aut├¬ntica</span></li>\n                    <li className=\"flex items-center gap-2\">ÔÇó <span className=\"text-sm\">Magnetismo pessoal elevado</span></li>\n                    <li className=\"flex items-center gap-2\">ÔÇó <span className=\"text-sm\">Coer├¬ncia estrat├®gica</span></li>\n                  </ul>\n               </div>\n               <div className=\"bg-stone-50/50 rounded-3xl p-8 border border-stone-100\">\n                  <h4 className=\"text-stone-900 font-bold mb-4 flex items-center gap-3 text-lg\">\n                    <Sparkles className=\"w-5 h-5 text-[#B48D6C]\" /> Pr├│ximos Passos\n                  </h4>\n                  <p className=\"text-stone-600 text-sm leading-relaxed italic\">\n                    Sua jornada continua no painel principal, onde voc├¬ encontrar├í sugest├Áes de looks baseadas no seu arqu├®tipo.\n                  </p>\n               </div>\n            </div>\n\n            <div className=\"flex flex-col gap-4 max-w-md mx-auto\">\n              <Button \n                className=\"bg-stone-900 hover:bg-stone-800 text-stone-50 h-16 rounded-2xl font-bold text-lg shadow-2xl transition-all hover:scale-[1.02] active:scale-95\"\n                onClick={() => router.push('/client/dashboard')}\n              >\n                Ir para o Dashboard\n              </Button>\n              <Button \n                variant=\"ghost\"\n                className=\"text-stone-400 hover:text-stone-900 h-12 gap-2 hover:bg-stone-50 rounded-xl transition-all\"\n                onClick={() => window.location.reload()}\n              >\n                <RefreshCw className=\"w-4 h-4\" /> Refazer Quiz\n              </Button>\n            </div>\n          </div>\n        </div>\n      </div>\n    )\n  }\n\n  return (\n    <div className=\"max-w-3xl mx-auto py-12 px-4 min-h-[90vh] flex flex-col animate-in fade-in slide-in-from-bottom-6 duration-700 text-stone-900\">\n      <div className=\"mb-12 text-center\">\n        <Button variant=\"ghost\" className=\"mb-8 text-stone-400 hover:text-stone-900 transition-colors hover:bg-stone-50\" onClick={() => router.push('/client/quiz')}>\n          <ArrowLeft className=\"w-4 h-4 mr-2\" /> Desistir da Jornada\n        </Button>\n        <div className=\"inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-[#B48D6C]/10 text-[#B48D6C] text-[10px] font-bold uppercase tracking-[0.2em] mb-6 border border-[#B48D6C]/10\">\n          <Sparkles className=\"w-4 h-4 animate-pulse\" />\n          Mapeamento Arquet├¡pico\n        </div>\n        <h1 className=\"text-5xl font-serif font-bold text-stone-900 mb-3 tracking-tight\">Desperte sua Ess├¬ncia</h1>\n        <p className=\"text-stone-500 text-lg max-w-lg mx-auto\">Responda com seu cora├º├úo para descobrir sua imagem magn├®tica.</p>\n      </div>\n\n      <div className=\"mb-10 max-w-md mx-auto w-full\">\n        <div className=\"flex justify-between text-[11px] font-bold text-stone-400 uppercase tracking-[0.2em] mb-4\">\n          <span>Passo {currentStep + 1} de {questions.length}</span>\n          <span>{Math.round(progress)}%</span>\n        </div>\n        <Progress value={progress} className=\"h-2 bg-stone-100 rounded-full\" />\n      </div>\n\n      <Card className=\"border-stone-200/50 shadow-[0_32px_64px_-16px_rgba(0,0,0,0.1)] bg-white/95 backdrop-blur-2xl rounded-[3rem] overflow-hidden border-b-[8px] border-stone-100/80 transition-all duration-500\">\n        <CardHeader className=\"pb-10 pt-16 px-8 md:px-14 text-center\">\n          <CardTitle className=\"text-3xl md:text-4xl font-serif font-bold leading-tight text-stone-900 tracking-tight\">\n            {currentQ.question}\n          </CardTitle>\n        </CardHeader>\n        <CardContent className=\"px-8 md:px-14 pb-16\">\n          <div className=\"grid grid-cols-1 gap-4\">\n            {currentQ.options.map((opt, idx) => (\n              <button\n                key={opt.id}\n                onClick={() => setAnswers({...answers, [currentStep]: opt.archetype})}\n                className={`flex items-center justify-between p-7 rounded-[2rem] border-2 transition-all duration-500 group relative overflow-hidden\n                  ${answers[currentStep] === opt.archetype \n                    ? 'border-[#B48D6C] bg-[#B48D6C]/5 shadow-lg' \n                    : 'border-stone-100 bg-white hover:border-stone-200 hover:shadow-md'\n                  }`}\n              >\n                <div className=\"flex items-center gap-6 relative z-10\">\n                   <span className={`w-10 h-10 rounded-xl flex items-center justify-center text-sm font-bold transition-all duration-500\n                    ${answers[currentStep] === opt.archetype ? 'bg-[#B48D6C] text-white rotate-6' : 'bg-stone-50 text-stone-400 group-hover:bg-[#B48D6C]/10 group-hover:text-[#B48D6C]'}\n                   `}>\n                     {String.fromCharCode(65 + idx)}\n                   </span>\n                   <span className={`text-left text-lg transition-all duration-500 ${answers[currentStep] === opt.archetype ? 'text-stone-900 font-bold tracking-tight transform translate-x-1' : 'text-stone-600 font-medium'}`}>\n                     {opt.text}\n                   </span>\n                </div>\n                {answers[currentStep] === opt.archetype && (\n                  <motion.div initial={{ scale: 0 }} animate={{ scale: 1 }}>\n                    <CheckCircle2 className=\"w-7 h-7 text-[#B48D6C]\" />\n                  </motion.div>\n                )}\n              </button>\n            ))}\n          </div>\n        </CardContent>\n        <CardFooter className=\"px-8 md:px-14 py-10 flex flex-col md:flex-row gap-4 justify-between bg-stone-50/40 border-t border-stone-100/60 mt-auto\">\n          <Button \n            variant=\"ghost\" \n            size=\"lg\" \n            onClick={handleBack} \n            disabled={currentStep === 0} \n            className=\"text-stone-400 font-bold text-[10px] uppercase tracking-[0.2em] h-14 px-8 hover:bg-white hover:text-stone-900 rounded-2xl disabled:opacity-30\"\n          >\n            Anterior\n          </Button>\n          <Button \n            size=\"lg\"\n            onClick={handleNext} \n            disabled={!answers[currentStep] || isSaving}\n            className=\"bg-stone-900 text-stone-50 hover:bg-stone-800 transition-all shadow-2xl px-12 rounded-2xl font-bold h-16 text-lg min-w-[200px] active:scale-95 disabled:bg-stone-200\"\n          >\n            {isSaving ? 'Salvando...' : currentStep === questions.length - 1 ? 'Mapear Agora' : 'Pr├│xima'} <ArrowRight className=\"w-5 h-5 ml-3\" />\n          </Button>\n        </CardFooter>\n      </Card>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\israe\\aplicatvo marry\\src\\app\\client\\quiz\\color\\page.tsx","messages":[],"suppressedMessages":[{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":203,"column":19,"nodeType":"JSXOpeningElement","endLine":203,"e