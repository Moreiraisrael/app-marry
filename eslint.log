ed-xl transition-all\">\n                                   <ChevronRight className=\"w-5 h-5\" />\n                                </Button>\n                             </td>\n                          </tr>\n                       ))}\n                    </tbody>\n                 </table>\n               )}\n            </div>\n         </Card>\n\n         <div className=\"space-y-8\">\n            <Card className=\"border-none bg-primary p-10 rounded-[2.5rem] text-primary-foreground relative overflow-hidden group shadow-xl shadow-primary/20\">\n               <div className=\"absolute top-0 right-0 w-48 h-48 bg-white/10 rounded-full -mr-10 -mt-10 blur-3xl group-hover:scale-110 transition-transform duration-700\" />\n               <div className=\"relative z-10 space-y-8\">\n                  <div className=\"w-16 h-16 rounded-[2rem] bg-white flex items-center justify-center shadow-xl shadow-black/5\">\n                     <Gift className=\"text-primary w-8 h-8\" />\n                  </div>\n                  <div className=\"space-y-3\">\n                     <h3 className=\"text-2xl font-bold\">Programa de Fidelidade</h3>\n                     <p className=\"text-sm text-white/70 leading-relaxed font-medium\">Voc├¬ atingiu 85% da meta para o selo <span className=\"text-white font-bold underline decoration-2 underline-offset-4\">Black Diamond</span>. Continue recomendando.</p>\n                  </div>\n                  <div className=\"h-3 w-full bg-black/10 rounded-full overflow-hidden\">\n                     <motion.div \n                       initial={{ width: 0 }}\n                       animate={{ width: '85%' }}\n                       transition={{ duration: 2, ease: \"easeOut\" }}\n                       className=\"h-full bg-white\"\n                     />\n                  </div>\n                  <Button className=\"w-full bg-white text-primary hover:bg-white/90 font-bold h-14 rounded-2xl shadow-lg border-none text-base\">\n                     Ver Benef├¡cios\n                  </Button>\n               </div>\n            </Card>\n\n            <Card className=\"border-none bg-card/60 backdrop-blur-md shadow-sm p-10 rounded-[2.5rem] space-y-6\">\n               <h4 className=\"text-primary font-bold text-[10px] uppercase tracking-[0.2em]\">Suporte ao Afiliado</h4>\n               <p className=\"text-muted-foreground text-sm leading-relaxed font-medium\">Algum problema com suas comiss├Áes? Nossa equipe t├®cnica est├í dispon├¡vel para analisar qualquer diverg├¬ncia.</p>\n               <Button variant=\"link\" className=\"text-primary p-0 h-auto font-bold flex items-center gap-2 group text-base hover:no-underline underline-offset-8 decoration-primary/30\">\n                  Abrir Ticket de Suporte <ArrowUpRight className=\"w-5 h-5 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform\" />\n               </Button>\n            </Card>\n         </div>\n      </div>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\israe\\aplicatvo marry\\src\\app\\consultant\\appointments\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\israe\\aplicatvo marry\\src\\app\\consultant\\capsule\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\israe\\aplicatvo marry\\src\\app\\consultant\\clients\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\israe\\aplicatvo marry\\src\\app\\consultant\\color-analysis\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCou